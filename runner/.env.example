# FreeUltraCode Remote Runner configuration
# Copy to .env and adjust. All values are optional except FUC_RUNNER_TOKEN.

# Bearer token the desktop client must send. REQUIRED in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
FUC_RUNNER_TOKEN=

# Bind address / port.
FUC_RUNNER_HOST=0.0.0.0
FUC_RUNNER_PORT=8787

# Where cloned repos / job working dirs live on this server.
FUC_RUNNER_WORKDIR=./workspaces

# Persistent metadata (jobs index, workspace records).
FUC_RUNNER_DATADIR=./data

# Max concurrent jobs.
FUC_RUNNER_MAX_CONCURRENCY=2

# Per-job wall-clock timeout (seconds).
FUC_RUNNER_JOB_TIMEOUT=1800

# Comma-separated allowlist of shell commands the AI agent may invoke directly
# via the /exec endpoint. Empty = exec endpoint disabled.
FUC_RUNNER_EXEC_ALLOWLIST=

# --- Model defaults (the server's OWN keys; clients may override per job) ---
# These let you keep keys on the server instead of shipping them from clients.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
